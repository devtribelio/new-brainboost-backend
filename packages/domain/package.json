{
  "name": "@bb/domain",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "development": "./src/*.ts",
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@bb/common": "workspace:*",
    "@bb/db": "workspace:*",
    "@prisma/client": "^5.22.0",
    "google-auth-library": "^10.6.2",
    "nanoid": "^5.1.11",
    "xendit-node": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0"
  }
}
