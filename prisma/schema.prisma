generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// Member / auth
// ============================================================================

model Member {
  id                  String    @id @default(uuid(7)) @db.Uuid
  legacyId            Int?      @unique
  code                String?   @unique
  email               String    @unique
  username            String?   @unique
  phone               String?   @unique
  phoneCode           String?
  fullName            String?
  firstName           String?
  lastName            String?
  passwordHash        String
  passwordAlgo        String    @default("bcrypt")
  googleSub           String?   @unique
  avatarUrl           String?
  coverUrl            String?
  bio                 String?
  isActive            Boolean   @default(true)
  isVerified          Boolean   @default(false)
  isPhoneVerified     Boolean   @default(false)
  isMuted             Boolean   @default(false)
  isBanned            Boolean   @default(false)
  gender              String?
  birthdate           DateTime?
  affiliateCode       String?   @unique
  affiliateBased      String    @default("PERFORMANCE") // "PERFORMANCE" | "GROWTH" | "INACTIVE"
  inviterId           String?   @db.Uuid
  inviterNetworkId    String?   @db.Uuid
  registerFrom        String?
  utmSource           String?
  utmContent          String?
  scheduledDeletionAt DateTime?
  lastActiveAt        DateTime?
  latitude            Float?
  longitude           Float?
  notificationsEnabled Boolean  @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  profile              MemberProfile?
  devices              Device[]
  refreshTokens        RefreshToken[]
  posts                Post[]
  comments             Comment[]
  notifications        Notification[]
  topicSubs            TopicSubscription[]
  postLikes            PostLike[]
  commentLikes         CommentLike[]
  inviter              Member?               @relation("MemberInviter", fields: [inviterId], references: [id])
  invitees             Member[]              @relation("MemberInviter")
  memberAffiliators    MemberAffiliator[]    @relation("MemberAffiliatorMember")
  affiliateCommissions AffiliateCommission[] @relation("AffiliateCommissionRecipient")
  affiliateVisits      AffiliateVisit[]      @relation("AffiliateVisitAffiliator")
  courseEnrollments    CourseEnrollment[]
  commerceTransactions CommerceTransaction[]
  commercePayments     CommercePayment[]
  notificationMutes    NotificationMute[]

  @@map("members")
}

model MemberProfile {
  id         String   @id @default(uuid(7)) @db.Uuid
  memberId   String   @unique @db.Uuid
  countryId  String?  @db.Uuid
  provinceId String?  @db.Uuid
  cityId     String?  @db.Uuid
  districtId String?  @db.Uuid
  address    String?
  postalCode String?
  updatedAt  DateTime @updatedAt

  member   Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)
  country  Country?  @relation(fields: [countryId], references: [id])
  province Province? @relation(fields: [provinceId], references: [id])
  city     City?     @relation(fields: [cityId], references: [id])
  district District? @relation(fields: [districtId], references: [id])

  @@map("member_profiles")
}

model Device {
  id         String   @id @default(uuid(7)) @db.Uuid
  memberId   String   @db.Uuid
  deviceId   String
  platform   String
  fcmToken   String?
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([memberId, deviceId])
  @@map("devices")
}

model RefreshToken {
  id         String    @id @default(uuid(7)) @db.Uuid
  memberId   String    @db.Uuid
  token      String    @unique
  clientType String    @default("mobile")
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([memberId, clientType, revokedAt])
  @@map("refresh_tokens")
}

model OtpCode {
  id        String    @id @default(uuid(7)) @db.Uuid
  target    String
  code      String
  purpose   String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([target, purpose])
  @@map("otp_codes")
}

model PraMember {
  id                String   @id @default(uuid(7)) @db.Uuid
  email             String?
  phone             String?
  affiliateMemberId String?  @db.Uuid
  networkId         String?  @db.Uuid
  device            Json?
  expiresAt         DateTime
  createdAt         DateTime @default(now())

  @@index([email])
  @@index([phone])
  @@map("pra_members")
}

// ============================================================================
// Location
// ============================================================================

model Country {
  id        String          @id @default(uuid(7)) @db.Uuid
  legacyId  Int?            @unique
  name      String
  code      String?         @unique
  provinces Province[]
  profiles  MemberProfile[]

  @@map("countries")
}

model Province {
  id        String          @id @default(uuid(7)) @db.Uuid
  legacyId  Int?            @unique
  countryId String          @db.Uuid
  name      String
  cities    City[]
  country   Country         @relation(fields: [countryId], references: [id])
  profiles  MemberProfile[]

  @@index([countryId])
  @@map("provinces")
}

model City {
  id         String          @id @default(uuid(7)) @db.Uuid
  legacyId   Int?            @unique
  provinceId String          @db.Uuid
  name       String
  districts  District[]
  province   Province        @relation(fields: [provinceId], references: [id])
  profiles   MemberProfile[]

  @@index([provinceId])
  @@map("cities")
}

model District {
  id       String          @id @default(uuid(7)) @db.Uuid
  legacyId Int?            @unique
  cityId   String          @db.Uuid
  name     String
  city     City            @relation(fields: [cityId], references: [id])
  profiles MemberProfile[]

  @@index([cityId])
  @@map("districts")
}

// ============================================================================
// Banner & product
// ============================================================================

model Banner {
  id        String   @id @default(uuid(7)) @db.Uuid
  legacyId  Int?     @unique
  title     String
  imageUrl  String
  linkUrl   String?
  position  Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("banners")
}

model Product {
  id              String   @id @default(uuid(7)) @db.Uuid
  legacyId        Int?     @unique
  type            String
  code            String?  @unique // legacy `course.code` — short alphanumeric id
  slug            String? // SEO-friendly slug from legacy `course.slug`
  title           String
  description     String?
  descriptionHtml String? // legacy `course.description_html` — rich HTML
  thumbnail       String? // legacy resource (model_type=TBModel_Course, collection=courseImage)
  price           Int      @default(0)
  marketingLink   String? // legacy `course.marketing_link`
  sellingPoints   Json? // legacy `course.selling_point` — JSONB string[]
  status          String   @default("active") // legacy: active|inactive|draft|archived
  tags            String? // legacy `course.tags` raw csv
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  course               Course?
  reviews              Review[]
  affiliatePrograms    AffiliateProgram[]
  affiliateCommissions AffiliateCommission[]
  commerceTransactions CommerceTransaction[]
  vouchers             Voucher[]

  @@map("products")
}

model Course {
  id             String  @id @default(uuid(7)) @db.Uuid
  productId      String  @unique @db.Uuid
  legacyCourseId Int?    @unique // legacy `course.id` int — emitted as `courseId` in response
  durationMin    Int     @default(0)
  level          String?
  contentRef     String?

  product     Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  sections    CourseSection[]
  enrollments CourseEnrollment[]

  @@map("courses")
}

model CourseEnrollment {
  id                 String    @id @default(uuid(7)) @db.Uuid
  legacyId           Int?      @unique
  memberId           String    @db.Uuid
  courseId           String    @db.Uuid
  progress           Float     @default(0)
  dateStart          DateTime?
  dateEnd            DateTime?
  expiredDate        DateTime?
  isCanceled         Boolean   @default(false)
  cancelationReason  String?
  certificateCode    String?
  certificateCreated DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([memberId, courseId])
  @@index([memberId, createdAt])
  @@map("course_enrollment")
}

model CourseSection {
  id              String   @id @default(uuid(7)) @db.Uuid
  legacySectionId Int      @unique @default(autoincrement()) // emit as `courseSectionId` int legacy
  courseId        String   @db.Uuid
  name            String
  order           Int      @default(0)
  createdAt       DateTime @default(now())

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@index([courseId, order])
  @@map("course_sections")
}

model Lesson {
  id             String   @id @default(uuid(7)) @db.Uuid
  legacyLessonId Int      @unique @default(autoincrement()) // emit as `courseLessonId` int legacy
  sectionId      String   @db.Uuid
  name           String // legacy `lessonName`
  description    String? // legacy `lessonDescription`
  slidesData     Json? // legacy `course_lesson.slides_data` — array of slide objects
  code           String?  @unique // legacy `code`
  slug           String? // legacy `slug`
  lessonStatus   String   @default("ACTIVE") // legacy `lesson_status`
  isPreview      Boolean  @default(false) // legacy `is_preview` (emit as int 0/1)
  duration       Int      @default(0) // legacy `duration` seconds
  order          Int      @default(0)
  createdAt      DateTime @default(now())

  section CourseSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([sectionId, order])
  @@map("course_lessons")
}

model Review {
  id        String   @id @default(uuid(7)) @db.Uuid
  productId String   @db.Uuid
  memberId  String   @db.Uuid
  stars     Int // 1..5, validated in service
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, memberId])
  @@index([productId, stars])
  @@map("reviews")
}

// ============================================================================
// Community: topic, post, comment, reply, network
// ============================================================================

model Topic {
  id          String   @id @default(uuid(7)) @db.Uuid
  legacyId    Int?     @unique
  networkId   String?  @db.Uuid
  name        String
  description String?
  iconUrl     String?
  iconType    String?  // "emoji" | "image" — null when no icon
  type        String   @default("PUBLIC")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  network       Network?            @relation(fields: [networkId], references: [id], onDelete: Cascade)
  posts         Post[]
  subscriptions TopicSubscription[]
  joinRequests  TopicJoinRequest[]

  @@index([networkId])
  @@index([name])
  @@map("topics")
}

enum JoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model TopicJoinRequest {
  id        String            @id @default(uuid(7)) @db.Uuid
  topicId   String            @db.Uuid
  memberId  String            @db.Uuid
  status    JoinRequestStatus @default(PENDING)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  topic Topic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([topicId, memberId])
  @@index([memberId])
  @@map("topic_join_requests")
}

model TopicSubscription {
  id        String   @id @default(uuid(7)) @db.Uuid
  memberId  String   @db.Uuid
  topicId   String   @db.Uuid
  createdAt DateTime @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
  topic  Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([memberId, topicId])
  @@map("topic_subscriptions")
}

model Post {
  id            String    @id @default(uuid(7)) @db.Uuid
  legacyId      Int?      @unique
  authorId      String    @db.Uuid
  topicId       String?   @db.Uuid
  networkId     String?   @db.Uuid
  title         String?
  content       String
  excerpt       String?
  postType      String?
  imageUrls     String[]
  videoUrl      String?
  embedUrl      String?
  publishStatus String    @default("PUBLISHED")
  publishAt     DateTime?
  countLike     Int       @default(0)
  countComment  Int       @default(0)
  countReplies  Int       @default(0)
  viewCount     Int       @default(0)
  isPinned      Boolean   @default(false)
  engagedAt     DateTime?
  isDeleted     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  author   Member       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  topic    Topic?       @relation(fields: [topicId], references: [id])
  comments Comment[]
  likes    PostLike[]
  reports  PostReport[]

  @@index([authorId])
  @@index([topicId])
  @@map("posts")
}

model PostLike {
  id        String   @id @default(uuid(7)) @db.Uuid
  postId    String   @db.Uuid
  memberId  String   @db.Uuid
  createdAt DateTime @default(now())

  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([postId, memberId])
  @@map("post_likes")
}

model PostReport {
  id           String       @id @default(uuid(7)) @db.Uuid
  postId       String       @db.Uuid
  reporterId   String       @db.Uuid
  categoryId   String       @db.Uuid
  networkId    String?      @db.Uuid
  reason       String?
  reportStatus ReportStatus @default(REPORTED)
  createdAt    DateTime     @default(now())

  post     Post           @relation(fields: [postId], references: [id], onDelete: Cascade)
  category ReportCategory @relation(fields: [categoryId], references: [id])

  @@index([postId])
  @@map("post_reports")
}

model Comment {
  id           String   @id @default(uuid(7)) @db.Uuid
  legacyId     Int?     @unique
  postId       String   @db.Uuid
  authorId     String   @db.Uuid
  parentId     String?  @db.Uuid
  content      String
  imageUrls    String[]
  // First URL extracted from content at create time. Mobile renders a link
  // preview from this. Mirrors legacy TBModel_Comment.embed_url. Full OG
  // metadata (title/description/image) is deferred — FE fetches client-side
  // if needed.
  embedUrl     String?
  countLike    Int      @default(0)
  countReplies Int      @default(0)
  isDeleted    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  post    Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  author  Member        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent  Comment?      @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies Comment[]     @relation("CommentReplies")
  likes   CommentLike[]

  @@index([postId])
  @@index([parentId])
  @@map("comments")
}

model CommentLike {
  id        String   @id @default(uuid(7)) @db.Uuid
  commentId String   @db.Uuid
  memberId  String   @db.Uuid
  createdAt DateTime @default(now())

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  member  Member  @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([commentId, memberId])
  @@map("comment_likes")
}

model Network {
  id          String   @id @default(uuid(7)) @db.Uuid
  legacyId    Int?     @unique
  code        String?  @unique
  name        String
  purpose     String? // "timeline" | "education" | null — used by /member/info community list
  description String?
  iconUrl     String?
  bannerUrl   String?
  countMember Int      @default(0)
  memberQuota Int?
  isPaid      Boolean  @default(false)
  isPublic    Boolean  @default(true)
  isHelpdesk  Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  members        NetworkMember[]
  memberRequests NetworkMemberRequest[]
  bannedMembers  NetworkBannedMember[]
  tags           NetworkTag[]
  topics         Topic[]

  @@index([name])
  @@map("networks")
}

model NetworkMemberRequest {
  id        String            @id @default(uuid(7)) @db.Uuid
  networkId String            @db.Uuid
  memberId  String            @db.Uuid
  status    JoinRequestStatus @default(PENDING)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  network Network @relation(fields: [networkId], references: [id], onDelete: Cascade)

  @@unique([networkId, memberId])
  @@index([memberId])
  @@map("network_member_requests")
}

model NetworkBannedMember {
  id        String   @id @default(uuid(7)) @db.Uuid
  networkId String   @db.Uuid
  memberId  String   @db.Uuid
  reason    String?
  bannedAt  DateTime @default(now())

  network Network @relation(fields: [networkId], references: [id], onDelete: Cascade)

  @@unique([networkId, memberId])
  @@map("network_banned_members")
}

model NetworkTeamMember {
  id        String   @id @default(uuid(7)) @db.Uuid
  networkId String   @db.Uuid
  memberId  String   @db.Uuid
  role      String   @default("MODERATOR")
  createdAt DateTime @default(now())

  @@unique([networkId, memberId])
  @@index([memberId])
  @@map("network_team_members")
}

model NetworkMember {
  id        String   @id @default(uuid(7)) @db.Uuid
  legacyId  Int?     @unique
  networkId String   @db.Uuid
  memberId  String   @db.Uuid
  joinedAt  DateTime @default(now())
  // Per-network moderation flag. Set by team/admin to silence a member in this
  // tribe without removing them. Blocks post create, comment, and like.
  // Mirrors legacy TBApi::validateMemberMuteNetwork.
  isMuted   Boolean  @default(false)

  network Network @relation(fields: [networkId], references: [id], onDelete: Cascade)

  @@unique([networkId, memberId])
  @@map("network_members")
}

model NetworkTag {
  id        String   @id @default(uuid(7)) @db.Uuid
  networkId String   @db.Uuid
  name      String
  createdAt DateTime @default(now())

  network Network @relation(fields: [networkId], references: [id], onDelete: Cascade)

  @@unique([networkId, name])
  @@map("network_tags")
}

// ============================================================================
// Report
// ============================================================================

model ReportCategory {
  id        String   @id @default(uuid(7)) @db.Uuid
  legacyId  Int?     @unique
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  postReports   PostReport[]
  memberReports MemberReport[]

  @@map("report_categories")
}

enum ReportStatus {
  REPORTED
  REVIEWED
  RESOLVED
  DISMISSED
}

model MemberReport {
  id           String       @id @default(uuid(7)) @db.Uuid
  reporterId   String       @db.Uuid
  targetId     String       @db.Uuid
  categoryId   String       @db.Uuid
  networkId    String?      @db.Uuid
  reason       String?
  reportStatus ReportStatus @default(REPORTED)
  createdAt    DateTime     @default(now())

  category ReportCategory @relation(fields: [categoryId], references: [id])

  @@index([targetId])
  @@index([reporterId])
  @@map("member_reports")
}

// ============================================================================
// Notification
// ============================================================================

model Notification {
  id         String    @id @default(uuid(7)) @db.Uuid
  memberId   String    @db.Uuid
  networkId  String?   @db.Uuid
  type       String
  notifGroup String?
  title      String
  body       String?
  payload    Json?
  url        String?
  dedupeKey  String?   @unique
  seenAt     DateTime?
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId, readAt])
  @@index([memberId, networkId])
  @@index([memberId, seenAt])
  @@map("notifications")
}

model NotificationMute {
  memberId  String   @db.Uuid
  scope     String
  refId     String   @db.Uuid
  createdAt DateTime @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@id([memberId, scope, refId])
  @@index([scope, refId])
  @@map("notification_mutes")
}

// ============================================================================
// Affiliate
// ============================================================================

/// Affiliate program per produk. `code` = public-facing reference di link.
/// Source: legacy `network_account_product_affiliator` (simplified, single-tenant).
model AffiliateProgram {
  id        String   @id @default(uuid(7)) @db.Uuid
  legacyId  Int?     @unique
  productId String?  @db.Uuid
  code      String   @unique
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product      Product?              @relation(fields: [productId], references: [id])
  affiliators  MemberAffiliator[]
  commissions  AffiliateCommission[]
  visits       AffiliateVisit[]
  transactions CommerceTransaction[]

  @@index([productId])
  @@map("affiliate_programs")
}

/// Member terdaftar sebagai promoter program.
/// Source: legacy `member_product_affiliator` (simplified, no pixel/request).
model MemberAffiliator {
  id        String    @id @default(uuid(7)) @db.Uuid
  legacyId  Int?      @unique
  memberId  String    @db.Uuid
  programId String    @db.Uuid
  exitState String?
  exitAt    DateTime?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  member  Member           @relation("MemberAffiliatorMember", fields: [memberId], references: [id], onDelete: Cascade)
  program AffiliateProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

  commissions  AffiliateCommission[]
  transactions CommerceTransaction[]

  @@unique([memberId, programId])
  @@index([programId])
  @@map("member_affiliators")
}

/// Commission ledger. 1 row per (payment, recipient, level).
/// Source: legacy `affiliator_commision`.
model AffiliateCommission {
  id                 String    @id @default(uuid(7)) @db.Uuid
  legacyId           Int?      @unique
  recipientId        String    @db.Uuid
  affiliatorId       String?   @db.Uuid
  programId          String?   @db.Uuid
  productId          String?   @db.Uuid
  paymentId          String?   @db.Uuid
  paymentLegacyId    Int?
  buyerMemberId      String?   @db.Uuid
  level              Int       @default(1)
  affiliateBased     String // "PERFORMANCE" | "GROWTH" | "INACTIVE" snapshot
  schemaType         String? // "SCHEMA_1" | "SCHEMA_2" | "SCHEMA_3" (PERFORMANCE only)
  productPrice       Int       @default(0)
  voucherAmount      Int       @default(0)
  commissionRate     Int // % yang dipakai (20/30/40/10/5)
  amount             Int       @default(0) // priceRecipient
  status             String    @default("PENDING") // PENDING | BALANCE | VOIDED
  approvedAt         DateTime?
  voidedAt           DateTime?
  voidedBy           String?   @db.Uuid
  voidedReason       String?
  source             String? // DEEPLINK | WEB | INSTALL_REFERRER
  attributionVisitId String?   @db.Uuid
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  recipient  Member            @relation("AffiliateCommissionRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  affiliator MemberAffiliator? @relation(fields: [affiliatorId], references: [id])
  program    AffiliateProgram? @relation(fields: [programId], references: [id])
  product    Product?          @relation(fields: [productId], references: [id])

  @@unique([paymentId, recipientId, level], name: "uniq_payment_recipient_level")
  @@index([recipientId, createdAt])
  @@index([programId])
  @@index([buyerMemberId])
  @@index([status])
  @@map("affiliate_commissions")
}

/// Affiliate link click log. Marketing-grade tracking + sumber attribution.
model AffiliateVisit {
  id                 String   @id @default(uuid(7)) @db.Uuid
  programId          String   @db.Uuid
  affiliatorMemberId String   @db.Uuid
  memberId           String?  @db.Uuid
  // marketing
  utmSource          String?
  utmMedium          String?
  utmCampaign        String?
  utmContent         String?
  utmTerm            String?
  adId               String?
  adNetwork          String? // "google" | "meta" | "tiktok"
  // device
  ipAddress          String?
  userAgent          String?
  referer            String?
  deviceId           String?
  platform           String? // "ios" | "android" | "web"
  appVersion         String?
  installReferrer    String?
  // raw escape-hatch
  rawQueryString     String?
  rawHeaders         Json?
  // idempotency
  clientEventId      String?  @unique
  createdAt          DateTime @default(now())

  program    AffiliateProgram @relation(fields: [programId], references: [id])
  affiliator Member           @relation("AffiliateVisitAffiliator", fields: [affiliatorMemberId], references: [id])

  @@index([programId, createdAt])
  @@index([affiliatorMemberId, createdAt])
  @@index([memberId])
  @@index([adId])
  @@index([utmCampaign])
  @@map("affiliate_visits")
}

// ============================================================================
// Commerce / Purchase (Xendit-only; CC + VA + eWallet; no IAP, no cart, no shipping)
// See docs/commerce-port.md
// ============================================================================

enum CommerceTransactionStatus {
  PENDING
  PAID
  EXPIRED
  FAILED
  REFUNDED
  CANCELED
}

enum CommercePaymentStatus {
  PENDING
  SUCCESS
  EXPIRED
  FAILED
  CANCELED
}

/// Order header. Snapshot price + voucher + attribution at checkout time.
model CommerceTransaction {
  id            String                    @id @default(uuid(7)) @db.Uuid
  legacyId      Int?                      @unique
  code          String                    @unique // BB-YYYYMMDD-####
  memberId      String                    @db.Uuid
  productId     String                    @db.Uuid
  qty           Int                       @default(1) // reserved; always 1 for course MVP
  itemTotal     Int                       @default(0)
  shippingTotal Int                       @default(0) // reserved; 0 for course MVP
  feeTotal      Int                       @default(0)
  voucherAmount Int                       @default(0)
  amount        Int                       @default(0) // grand total
  voucherCode   String?
  voucherId     String?                   @db.Uuid
  affiliatorId  String?                   @db.Uuid
  programId     String?                   @db.Uuid
  status        CommerceTransactionStatus @default(PENDING)
  paidAt        DateTime?
  canceledAt    DateTime?
  expiredAt     DateTime?
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt

  member     Member            @relation(fields: [memberId], references: [id])
  product    Product           @relation(fields: [productId], references: [id])
  affiliator MemberAffiliator? @relation(fields: [affiliatorId], references: [id])
  program    AffiliateProgram? @relation(fields: [programId], references: [id])
  voucher    Voucher?          @relation(fields: [voucherId], references: [id])
  payments   CommercePayment[]

  @@index([memberId, createdAt])
  @@index([status])
  @@index([expiredAt])
  @@map("commerce_transactions")
}

/// Payment attempt. Multi rows per transaction (VA retry possible after expiry).
model CommercePayment {
  id               String                @id @default(uuid(7)) @db.Uuid
  legacyId         Int?                  @unique
  transactionId    String                @db.Uuid
  memberId         String                @db.Uuid
  paymentType      String // "cc" | "va" | "eWallet" | "voucher"
  bank             String? // BCA / BNI / MANDIRI / BRI / PERMATA
  ewalletType      String? // OVO / DANA / LINKAJA / GOPAY / SHOPEEPAY
  amount           Int
  fee              Int                   @default(0)
  acceptedAmount   Int                   @default(0)
  status           CommercePaymentStatus @default(PENDING)
  vendorStatus     String?
  externalId       String?
  xenditId         String?               @unique // pr-xxx (PaymentRequest id)
  xenditPaymentMethodId String?          // pm-xxx (PaymentMethod id from SDK)
  paymentMethodId  String?               // pm-xxx supplied by mobile for CC charges
  vaNumber         String?
  checkoutUrl      String?               // eWallet WEB/MOBILE AUTH redirect (webview fallback)
  deeplinkUrl      String?               // eWallet DEEPLINK AUTH (open native eWallet app)
  cardMaskedNumber String?
  cardBrand        String?
  expiredAt        DateTime?
  paidAt           DateTime?
  logRequest       Json?
  logResponse      Json?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  transaction CommerceTransaction    @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  member      Member                 @relation(fields: [memberId], references: [id])
  events      CommercePaymentEvent[]

  @@index([transactionId])
  @@index([status, expiredAt])
  @@map("commerce_payments")
}

/// Audit trail of payment status transitions. Useful for Xendit re-delivery debugging.
model CommercePaymentEvent {
  id         String                 @id @default(uuid(7)) @db.Uuid
  paymentId  String                 @db.Uuid
  source     String // "checkout" | "webhook" | "poll" | "manual"
  fromStatus CommercePaymentStatus?
  toStatus   CommercePaymentStatus
  payload    Json?
  createdAt  DateTime               @default(now())

  payment CommercePayment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId, createdAt])
  @@map("commerce_payment_events")
}

/// Discount voucher. Legacy `voucher` table parity.
model Voucher {
  id        String    @id @default(uuid(7)) @db.Uuid
  legacyId  Int?      @unique
  code      String    @unique
  productId String?   @db.Uuid // null = global
  type      String // "PERCENT" | "AMOUNT"
  value     Int
  maxAmount Int? // cap for PERCENT
  quota     Int? // null = unlimited
  used      Int       @default(0)
  startsAt  DateTime?
  endsAt    DateTime?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  product      Product?              @relation(fields: [productId], references: [id])
  transactions CommerceTransaction[]

  @@map("vouchers")
}

// ============================================================================
// Admin (separate from Member — isolated admin panel auth)
// ============================================================================

enum AdminRole {
  SUPERADMIN
  ADMIN
}

model Admin {
  id           String    @id @default(uuid(7)) @db.Uuid
  email        String    @unique
  fullName     String
  passwordHash String
  role         AdminRole @default(ADMIN)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("admins")
}
