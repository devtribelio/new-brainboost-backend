generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// Member / auth
// ============================================================================

model Member {
  id           String   @id @default(cuid())
  legacyId     Int?     @unique
  code         String?  @unique
  email        String   @unique
  username     String?  @unique
  phone        String?  @unique
  phoneCode    String?
  fullName     String?
  firstName    String?
  lastName     String?
  passwordHash String
  passwordAlgo String   @default("bcrypt")
  avatarUrl    String?
  coverUrl     String?
  bio          String?
  isActive     Boolean  @default(true)
  isVerified   Boolean  @default(false)
  isPhoneVerified Boolean @default(false)
  isMuted      Boolean  @default(false)
  isBanned     Boolean  @default(false)
  gender       String?
  birthdate    DateTime?
  affiliateCode String? @unique
  inviterId    String?
  inviterNetworkId String?
  registerFrom String?
  utmSource    String?
  utmContent   String?
  scheduledDeletionAt DateTime?
  lastActiveAt DateTime?
  latitude     Float?
  longitude    Float?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profile       MemberProfile?
  devices       Device[]
  refreshTokens RefreshToken[]
  posts         Post[]
  comments      Comment[]
  notifications Notification[]
  topicSubs     TopicSubscription[]
  postLikes     PostLike[]
  commentLikes  CommentLike[]
  affiliateRequests   AffiliateRequest[]    @relation("AffiliateRequestMember")
  memberAffiliators   MemberAffiliator[]    @relation("MemberAffiliatorMember")
  affiliateCommissions AffiliateCommission[] @relation("AffiliateCommissionRecipient")

  @@map("members")
}

model MemberProfile {
  id         String   @id @default(cuid())
  memberId   String   @unique
  countryId  String?
  provinceId String?
  cityId     String?
  districtId String?
  address    String?
  postalCode String?
  updatedAt  DateTime @updatedAt

  member   Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)
  country  Country?  @relation(fields: [countryId], references: [id])
  province Province? @relation(fields: [provinceId], references: [id])
  city     City?     @relation(fields: [cityId], references: [id])
  district District? @relation(fields: [districtId], references: [id])

  @@map("member_profiles")
}

model Device {
  id            String   @id @default(cuid())
  memberId      String
  deviceId      String
  platform      String
  fcmToken      String?
  lastSeenAt    DateTime @default(now())
  createdAt     DateTime @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([memberId, deviceId])
  @@map("devices")
}

model RefreshToken {
  id        String   @id @default(cuid())
  memberId  String
  token     String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@map("refresh_tokens")
}

model OtpCode {
  id        String   @id @default(cuid())
  target    String
  code      String
  purpose   String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([target, purpose])
  @@map("otp_codes")
}

model PraMember {
  id                 String    @id @default(cuid())
  email              String?
  phone              String?
  affiliateMemberId  String?
  networkId          String?
  device             Json?
  expiresAt          DateTime
  createdAt          DateTime  @default(now())

  @@index([email])
  @@index([phone])
  @@map("pra_members")
}

// ============================================================================
// Location
// ============================================================================

model Country {
  id        String     @id @default(cuid())
  legacyId  Int?       @unique
  name      String
  code      String?    @unique
  provinces Province[]
  profiles  MemberProfile[]

  @@map("countries")
}

model Province {
  id        String  @id @default(cuid())
  legacyId  Int?    @unique
  countryId String
  name      String
  cities    City[]
  country   Country @relation(fields: [countryId], references: [id])
  profiles  MemberProfile[]

  @@index([countryId])
  @@map("provinces")
}

model City {
  id         String     @id @default(cuid())
  legacyId   Int?       @unique
  provinceId String
  name       String
  districts  District[]
  province   Province   @relation(fields: [provinceId], references: [id])
  profiles   MemberProfile[]

  @@index([provinceId])
  @@map("cities")
}

model District {
  id       String @id @default(cuid())
  legacyId Int?   @unique
  cityId   String
  name     String
  city     City   @relation(fields: [cityId], references: [id])
  profiles MemberProfile[]

  @@index([cityId])
  @@map("districts")
}

// ============================================================================
// Banner & product
// ============================================================================

model Banner {
  id        String   @id @default(cuid())
  legacyId  Int?     @unique
  title     String
  imageUrl  String
  linkUrl   String?
  position  Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("banners")
}

model Product {
  id          String   @id @default(cuid())
  legacyId    Int?     @unique
  type        String
  title       String
  description String?
  thumbnail   String?
  price       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course Course?
  affiliatePrograms    AffiliateProgram[]
  affiliateCommissions AffiliateCommission[]

  @@map("products")
}

model Course {
  id          String   @id @default(cuid())
  productId   String   @unique
  durationMin Int      @default(0)
  level       String?
  contentRef  String?

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("courses")
}

// ============================================================================
// Community: topic, post, comment, reply, network
// ============================================================================

model Topic {
  id          String   @id @default(cuid())
  legacyId    Int?     @unique
  networkId   String?
  name        String
  description String?
  iconUrl     String?
  type        String   @default("PUBLIC")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  network       Network? @relation(fields: [networkId], references: [id], onDelete: Cascade)
  posts         Post[]
  subscriptions TopicSubscription[]
  joinRequests  TopicJoinRequest[]

  @@index([networkId])
  @@index([name])
  @@map("topics")
}

enum JoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model TopicJoinRequest {
  id        String            @id @default(cuid())
  topicId   String
  memberId  String
  status    JoinRequestStatus @default(PENDING)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  topic Topic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([topicId, memberId])
  @@index([memberId])
  @@map("topic_join_requests")
}

model TopicSubscription {
  id        String   @id @default(cuid())
  memberId  String
  topicId   String
  createdAt DateTime @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
  topic  Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([memberId, topicId])
  @@map("topic_subscriptions")
}

model Post {
  id        String   @id @default(cuid())
  legacyId  Int?     @unique
  authorId  String
  topicId   String?
  networkId String?
  title     String?
  content   String
  excerpt   String?
  postType  String?
  imageUrls String[]
  videoUrl  String?
  embedUrl  String?
  publishStatus String @default("PUBLISHED")
  publishAt   DateTime?
  countLike    Int @default(0)
  countComment Int @default(0)
  countReplies Int @default(0)
  viewCount    Int @default(0)
  isPinned  Boolean  @default(false)
  engagedAt DateTime?
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author   Member    @relation(fields: [authorId], references: [id], onDelete: Cascade)
  topic    Topic?    @relation(fields: [topicId], references: [id])
  comments Comment[]
  likes    PostLike[]
  reports  PostReport[]

  @@index([authorId])
  @@index([topicId])
  @@map("posts")
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String
  memberId  String
  createdAt DateTime @default(now())

  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([postId, memberId])
  @@map("post_likes")
}

model PostReport {
  id           String       @id @default(cuid())
  postId       String
  reporterId   String
  categoryId   String
  networkId    String?
  reason       String?
  reportStatus ReportStatus @default(REPORTED)
  createdAt    DateTime     @default(now())

  post     Post           @relation(fields: [postId], references: [id], onDelete: Cascade)
  category ReportCategory @relation(fields: [categoryId], references: [id])

  @@index([postId])
  @@map("post_reports")
}

model Comment {
  id        String   @id @default(cuid())
  legacyId  Int?     @unique
  postId    String
  authorId  String
  parentId  String?
  content   String
  imageUrls String[]
  countLike    Int @default(0)
  countReplies Int @default(0)
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post    Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  author  Member    @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies Comment[] @relation("CommentReplies")
  likes   CommentLike[]

  @@index([postId])
  @@index([parentId])
  @@map("comments")
}

model CommentLike {
  id        String   @id @default(cuid())
  commentId String
  memberId  String
  createdAt DateTime @default(now())

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  member  Member  @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([commentId, memberId])
  @@map("comment_likes")
}

model Network {
  id          String   @id @default(cuid())
  legacyId    Int?     @unique
  name        String
  description String?
  iconUrl     String?
  bannerUrl   String?
  countMember Int      @default(0)
  memberQuota Int?
  isPaid      Boolean  @default(false)
  isPublic    Boolean  @default(true)
  isHelpdesk  Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  members         NetworkMember[]
  memberRequests  NetworkMemberRequest[]
  bannedMembers   NetworkBannedMember[]
  tags            NetworkTag[]
  topics          Topic[]
  affiliatePrograms AffiliateProgram[]

  @@index([name])
  @@map("networks")
}

model NetworkMemberRequest {
  id        String            @id @default(cuid())
  networkId String
  memberId  String
  status    JoinRequestStatus @default(PENDING)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  network Network @relation(fields: [networkId], references: [id], onDelete: Cascade)

  @@unique([networkId, memberId])
  @@index([memberId])
  @@map("network_member_requests")
}

model NetworkBannedMember {
  id        String   @id @default(cuid())
  networkId String
  memberId  String
  reason    String?
  bannedAt  DateTime @default(now())

  network Network @relation(fields: [networkId], references: [id], onDelete: Cascade)

  @@unique([networkId, memberId])
  @@map("network_banned_members")
}

model NetworkTeamMember {
  id        String   @id @default(cuid())
  networkId String
  memberId  String
  role      String   @default("MODERATOR")
  createdAt DateTime @default(now())

  @@unique([networkId, memberId])
  @@index([memberId])
  @@map("network_team_members")
}

model NetworkMember {
  id        String   @id @default(cuid())
  legacyId  Int?     @unique
  networkId String
  memberId  String
  joinedAt  DateTime @default(now())

  network Network @relation(fields: [networkId], references: [id], onDelete: Cascade)

  @@unique([networkId, memberId])
  @@map("network_members")
}

model NetworkTag {
  id        String  @id @default(cuid())
  networkId String
  name      String

  network Network @relation(fields: [networkId], references: [id], onDelete: Cascade)

  @@unique([networkId, name])
  @@map("network_tags")
}

// ============================================================================
// Report
// ============================================================================

model ReportCategory {
  id        String   @id @default(cuid())
  legacyId  Int?     @unique
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  postReports   PostReport[]
  memberReports MemberReport[]

  @@map("report_categories")
}

enum ReportStatus {
  REPORTED
  REVIEWED
  RESOLVED
  DISMISSED
}

model MemberReport {
  id           String       @id @default(cuid())
  reporterId   String
  targetId     String
  categoryId   String
  networkId    String?
  reason       String?
  reportStatus ReportStatus @default(REPORTED)
  createdAt    DateTime     @default(now())

  category ReportCategory @relation(fields: [categoryId], references: [id])

  @@index([targetId])
  @@index([reporterId])
  @@map("member_reports")
}

// ============================================================================
// Notification
// ============================================================================

model Notification {
  id           String   @id @default(cuid())
  memberId     String
  networkId    String?
  type         String
  notifGroup   String?
  title        String
  body         String?
  payload      Json?
  url          String?
  seenAt       DateTime?
  readAt       DateTime?
  createdAt    DateTime @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId, readAt])
  @@index([memberId, networkId])
  @@map("notifications")
}

// ============================================================================
// Commission
// ============================================================================

model CommissionEntry {
  id        String   @id @default(cuid())
  memberId  String
  amount    Int
  currency  String   @default("IDR")
  source    String?
  createdAt DateTime @default(now())

  @@index([memberId])
  @@map("commission_entries")
}

// ============================================================================
// Affiliate
// ============================================================================

enum AffiliateRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model AffiliateProgramCategory {
  id        String   @id @default(cuid())
  legacyId  Int?     @unique
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  programs AffiliateProgram[]

  @@map("affiliate_program_categories")
}

/// Affiliate program a network account offers for a product.
/// Source: legacy `network_account_product_affiliator`.
model AffiliateProgram {
  id                 String   @id @default(cuid())
  legacyId           Int?     @unique
  networkId          String?
  productId          String?
  categoryId         String?
  name               String?
  commissionType     String   @default("percent")
  commissionAmount   Int      @default(0)
  // Per-affiliator level overrides (legacy `pbs_*` columns)
  pbsCommissionType  String   @default("PERCENT")
  pbsAff1            Int      @default(20)
  pbsAff2            Int      @default(30)
  pbsAff3            Int      @default(40)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  network    Network?                  @relation(fields: [networkId], references: [id])
  product    Product?                  @relation(fields: [productId], references: [id])
  category   AffiliateProgramCategory? @relation(fields: [categoryId], references: [id])

  affiliators MemberAffiliator[]
  requests    AffiliateRequest[]
  commissions AffiliateCommission[]

  @@index([networkId])
  @@index([productId])
  @@map("affiliate_programs")
}

/// Member application to join an affiliate program.
/// Source: legacy `affiliate_request`.
model AffiliateRequest {
  id          String                 @id @default(cuid())
  legacyId    Int?                   @unique
  programId   String?
  memberId    String?
  inviterId   String?
  email       String?
  name        String?
  phone       String?
  fromSource  String?
  invitedType String?
  tags        String?
  reqStatus   AffiliateRequestStatus @default(PENDING)
  actionAt    DateTime?
  actionBy    String?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  program AffiliateProgram? @relation(fields: [programId], references: [id])
  member  Member?           @relation("AffiliateRequestMember", fields: [memberId], references: [id])

  @@index([programId])
  @@index([memberId])
  @@index([email])
  @@map("affiliate_requests")
}

/// Active affiliator record (member is approved promoter for a program).
/// Source: legacy `member_product_affiliator`.
model MemberAffiliator {
  id         String    @id @default(cuid())
  legacyId   Int?      @unique
  memberId   String
  programId  String
  requestId  String?
  exitState  String?
  exitAt     DateTime?
  fbPixelId  String?
  ttPixelId  String?
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  member  Member           @relation("MemberAffiliatorMember", fields: [memberId], references: [id], onDelete: Cascade)
  program AffiliateProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

  commissions AffiliateCommission[]

  @@unique([memberId, programId])
  @@index([programId])
  @@map("member_affiliators")
}

/// Commission earnings ledger.
/// Source: legacy `affiliator_commision`.
model AffiliateCommission {
  id              String   @id @default(cuid())
  legacyId        Int?     @unique
  recipientId     String
  affiliatorId    String?
  programId       String?
  productId       String?
  level           Int      @default(1)
  productPrice    Int      @default(0)
  commissionType  String   @default("percent")
  commissionAmount Int     @default(0)
  amount          Int      @default(0)
  feePercent      Int      @default(0)
  feeAmount       Int      @default(0)
  isPending       Boolean  @default(false)
  isExpired       Boolean  @default(false)
  isSuper         Boolean  @default(false)
  source          String?
  paymentLegacyId Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  recipient  Member            @relation("AffiliateCommissionRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  affiliator MemberAffiliator? @relation(fields: [affiliatorId], references: [id])
  program    AffiliateProgram? @relation(fields: [programId], references: [id])
  product    Product?          @relation(fields: [productId], references: [id])

  @@index([recipientId])
  @@index([programId])
  @@index([productId])
  @@map("affiliate_commissions")
}

// ============================================================================
// Admin (separate from Member — isolated admin panel auth)
// ============================================================================

enum AdminRole {
  SUPERADMIN
  ADMIN
}

model Admin {
  id           String    @id @default(cuid())
  email        String    @unique
  fullName     String
  passwordHash String
  role         AdminRole @default(ADMIN)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("admins")
}
