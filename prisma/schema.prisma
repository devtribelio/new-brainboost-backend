generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// Member / auth
// ============================================================================

model Member {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String?  @unique
  phone        String?  @unique
  fullName     String?
  passwordHash String
  avatarUrl    String?
  bio          String?
  isActive     Boolean  @default(true)
  isVerified   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profile       MemberProfile?
  devices       Device[]
  refreshTokens RefreshToken[]
  posts         Post[]
  comments      Comment[]
  notifications Notification[]
  topicSubs     TopicSubscription[]
  postLikes     PostLike[]
  commentLikes  CommentLike[]

  @@map("members")
}

model MemberProfile {
  id         String   @id @default(cuid())
  memberId   String   @unique
  countryId  String?
  provinceId String?
  cityId     String?
  districtId String?
  address    String?
  postalCode String?
  updatedAt  DateTime @updatedAt

  member   Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)
  country  Country?  @relation(fields: [countryId], references: [id])
  province Province? @relation(fields: [provinceId], references: [id])
  city     City?     @relation(fields: [cityId], references: [id])
  district District? @relation(fields: [districtId], references: [id])

  @@map("member_profiles")
}

model Device {
  id            String   @id @default(cuid())
  memberId      String
  deviceId      String
  platform      String
  fcmToken      String?
  lastSeenAt    DateTime @default(now())
  createdAt     DateTime @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([memberId, deviceId])
  @@map("devices")
}

model RefreshToken {
  id        String   @id @default(cuid())
  memberId  String
  token     String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@map("refresh_tokens")
}

model OtpCode {
  id        String   @id @default(cuid())
  target    String
  code      String
  purpose   String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([target, purpose])
  @@map("otp_codes")
}

// ============================================================================
// Location
// ============================================================================

model Country {
  id        String     @id @default(cuid())
  name      String
  code      String?    @unique
  provinces Province[]
  profiles  MemberProfile[]

  @@map("countries")
}

model Province {
  id        String  @id @default(cuid())
  countryId String
  name      String
  cities    City[]
  country   Country @relation(fields: [countryId], references: [id])
  profiles  MemberProfile[]

  @@index([countryId])
  @@map("provinces")
}

model City {
  id         String     @id @default(cuid())
  provinceId String
  name       String
  districts  District[]
  province   Province   @relation(fields: [provinceId], references: [id])
  profiles   MemberProfile[]

  @@index([provinceId])
  @@map("cities")
}

model District {
  id       String @id @default(cuid())
  cityId   String
  name     String
  city     City   @relation(fields: [cityId], references: [id])
  profiles MemberProfile[]

  @@index([cityId])
  @@map("districts")
}

// ============================================================================
// Banner & product
// ============================================================================

model Banner {
  id        String   @id @default(cuid())
  title     String
  imageUrl  String
  linkUrl   String?
  position  Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("banners")
}

model Product {
  id          String   @id @default(cuid())
  type        String
  title       String
  description String?
  thumbnail   String?
  price       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course Course?

  @@map("products")
}

model Course {
  id          String   @id @default(cuid())
  productId   String   @unique
  durationMin Int      @default(0)
  level       String?
  contentRef  String?

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("courses")
}

// ============================================================================
// Community: topic, post, comment, reply, network
// ============================================================================

model Topic {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  iconUrl     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  posts         Post[]
  subscriptions TopicSubscription[]

  @@map("topics")
}

model TopicSubscription {
  id        String   @id @default(cuid())
  memberId  String
  topicId   String
  createdAt DateTime @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
  topic  Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([memberId, topicId])
  @@map("topic_subscriptions")
}

model Post {
  id        String   @id @default(cuid())
  authorId  String
  topicId   String?
  content   String
  imageUrls String[]
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author   Member    @relation(fields: [authorId], references: [id], onDelete: Cascade)
  topic    Topic?    @relation(fields: [topicId], references: [id])
  comments Comment[]
  likes    PostLike[]
  reports  PostReport[]

  @@index([authorId])
  @@index([topicId])
  @@map("posts")
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String
  memberId  String
  createdAt DateTime @default(now())

  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([postId, memberId])
  @@map("post_likes")
}

model PostReport {
  id         String   @id @default(cuid())
  postId     String
  reporterId String
  categoryId String
  reason     String?
  createdAt  DateTime @default(now())

  post     Post           @relation(fields: [postId], references: [id], onDelete: Cascade)
  category ReportCategory @relation(fields: [categoryId], references: [id])

  @@map("post_reports")
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  authorId  String
  parentId  String?
  content   String
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post    Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  author  Member    @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies Comment[] @relation("CommentReplies")
  likes   CommentLike[]

  @@index([postId])
  @@index([parentId])
  @@map("comments")
}

model CommentLike {
  id        String   @id @default(cuid())
  commentId String
  memberId  String
  createdAt DateTime @default(now())

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  member  Member  @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([commentId, memberId])
  @@map("comment_likes")
}

model Network {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  iconUrl     String?
  createdAt   DateTime @default(now())

  members NetworkMember[]
  tags    NetworkTag[]

  @@map("networks")
}

model NetworkMember {
  id        String   @id @default(cuid())
  networkId String
  memberId  String
  joinedAt  DateTime @default(now())

  network Network @relation(fields: [networkId], references: [id], onDelete: Cascade)

  @@unique([networkId, memberId])
  @@map("network_members")
}

model NetworkTag {
  id        String  @id @default(cuid())
  networkId String
  name      String

  network Network @relation(fields: [networkId], references: [id], onDelete: Cascade)

  @@unique([networkId, name])
  @@map("network_tags")
}

// ============================================================================
// Report
// ============================================================================

model ReportCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  postReports   PostReport[]
  memberReports MemberReport[]

  @@map("report_categories")
}

model MemberReport {
  id         String   @id @default(cuid())
  reporterId String
  targetId   String
  categoryId String
  reason     String?
  createdAt  DateTime @default(now())

  category ReportCategory @relation(fields: [categoryId], references: [id])

  @@map("member_reports")
}

// ============================================================================
// Notification
// ============================================================================

model Notification {
  id        String   @id @default(cuid())
  memberId  String
  type      String
  title     String
  body      String?
  payload   Json?
  seenAt    DateTime?
  createdAt DateTime @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@map("notifications")
}

// ============================================================================
// Commission
// ============================================================================

model CommissionEntry {
  id        String   @id @default(cuid())
  memberId  String
  amount    Int
  currency  String   @default("IDR")
  source    String?
  createdAt DateTime @default(now())

  @@index([memberId])
  @@map("commission_entries")
}

// ============================================================================
// Admin (separate from Member — isolated admin panel auth)
// ============================================================================

enum AdminRole {
  SUPERADMIN
  ADMIN
}

model Admin {
  id           String    @id @default(cuid())
  email        String    @unique
  fullName     String
  passwordHash String
  role         AdminRole @default(ADMIN)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("admins")
}
