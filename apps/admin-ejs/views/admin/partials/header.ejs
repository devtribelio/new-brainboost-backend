<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> · bb-admin</title>
  <link rel="stylesheet" href="/admin/static/admin.css" />
</head>
<body>
  <div class="admin-shell">
    <aside class="admin-sidebar">
      <div class="brand">
        <a href="/admin">bb-admin</a>
      </div>
      <nav>
        <% (sidebar || []).forEach(function(section) { %>
          <div class="nav-section">
            <h4><%= section.label %></h4>
            <ul>
              <% section.links.forEach(function(link) { %>
                <li>
                  <a href="<%= link.href %>" class="<%= currentPath && currentPath.indexOf(link.href.replace('/admin','')) === 0 ? 'active' : '' %>">
                    <%= link.label %>
                  </a>
                </li>
              <% }); %>
            </ul>
          </div>
        <% }); %>
      </nav>
      <div class="sidebar-footer">
        <% if (admin) { %>
          <div class="who"><%= admin.fullName || admin.email %></div>
          <div class="role"><%= admin.role %></div>
          <a class="logout" href="/admin/logout">Logout</a>
        <% } %>
      </div>
    </aside>
    <main class="admin-main">
      <header class="admin-topbar">
        <h1><%= title %></h1>
      </header>
      <% if (typeof flash !== 'undefined' && flash) { %>
        <div class="flash flash-<%= flash.level %>"><%= flash.text %></div>
      <% } %>
      <section class="admin-content">
