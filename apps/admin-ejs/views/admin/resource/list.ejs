<%- include('../partials/header', { title, sidebar, currentPath, admin, flash }) %>

<div class="toolbar">
  <% if (cfg.searchField) { %>
    <form method="GET" action="/admin/<%= cfg.key %>" class="search-form">
      <input type="search" name="q" value="<%= search || '' %>" placeholder="Search <%= cfg.searchField %>…" />
      <button type="submit" class="btn">Search</button>
    </form>
  <% } else { %>
    <div></div>
  <% } %>
  <% if (canCreate) { %>
    <a class="btn btn-primary" href="/admin/<%= cfg.key %>/new">+ New <%= cfg.label %></a>
  <% } %>
</div>

<div class="table-wrap">
  <table class="data-table">
    <thead>
      <tr>
        <% cfg.listColumns.forEach(function(col) { %>
          <th><%= col.label %></th>
        <% }); %>
        <th class="actions-col">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if (rows.length === 0) { %>
        <tr><td colspan="<%= cfg.listColumns.length + 1 %>" class="empty">No records.</td></tr>
      <% } %>
      <% rows.forEach(function(row) { %>
        <tr>
          <% cfg.listColumns.forEach(function(col) { %>
            <td><%= col.format ? col.format(row[col.field], row) : formatCell(row[col.field]) %></td>
          <% }); %>
          <td class="actions">
            <% if (canEdit) { %>
              <a class="btn btn-sm" href="/admin/<%= cfg.key %>/<%= row[idField] %>/edit">Edit</a>
            <% } %>
            <% if (canDelete) { %>
              <form method="POST" action="/admin/<%= cfg.key %>/<%= row[idField] %>/delete" onsubmit="return confirm('Delete this <%= cfg.label %>?');" style="display:inline">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <button type="submit" class="btn btn-sm btn-danger">Delete</button>
              </form>
            <% } %>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>
</div>

<div class="pagination">
  <span>Page <%= meta.page %> / <%= meta.totalPages %> · <%= meta.total %> total</span>
  <% if (meta.hasPrev) { %>
    <a class="btn btn-sm" href="?page=<%= meta.page - 1 %><%= search ? '&q=' + encodeURIComponent(search) : '' %>">← Prev</a>
  <% } %>
  <% if (meta.hasNext) { %>
    <a class="btn btn-sm" href="?page=<%= meta.page + 1 %><%= search ? '&q=' + encodeURIComponent(search) : '' %>">Next →</a>
  <% } %>
</div>

<%- include('../partials/footer') %>
