{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@bb/common": ["../../packages/common/dist/index.d.ts"],
      "@bb/common/*": ["../../packages/common/dist/*"],
      "@bb/domain": ["../../packages/domain/dist/index.d.ts"],
      "@bb/domain/*": ["../../packages/domain/dist/*"],
      "@bb/db": ["../../packages/db/dist/index.d.ts"]
    }
  },
  "references": [
    { "path": "../../packages/db" },
    { "path": "../../packages/common" },
    { "path": "../../packages/domain" }
  ],
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "tests", "**/*.spec.ts"]
}
