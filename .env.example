# Application
NODE_ENV=development
PORT=3000
APP_NAME=bb-backend

# Database (Postgres)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bb_backend?schema=public"

# JWT
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Upload (placeholder local dir)
UPLOAD_TEMP_DIR=./tmp/uploads

# Logging
LOG_LEVEL=info
