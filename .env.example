# Application
NODE_ENV=development
PORT=3000
APP_NAME=bb-backend

# Database (Postgres)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bb_backend?schema=public"

# JWT
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
JWT_ANON_EXPIRES_IN=1h

# OAuth2 client_credentials grant (pre-login flows: splash banner, version check)
# Leave blank to disable client_credentials grant.
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=

# Google social login (grant_type=social, provider=google).
# CSV of OAuth2 client IDs whose id_tokens we accept. Mobile commonly has
# separate Android/iOS/Web client IDs — list all of them.
# Leave blank to disable Google sign-in.
GOOGLE_CLIENT_IDS=

# Admin panel
ADMIN_JWT_SECRET=change-me-admin
ADMIN_JWT_TTL=8h
ADMIN_COOKIE_NAME=bb_admin
# Used by `pnpm tsx prisma/seed-admin.ts` to bootstrap the first superadmin
ADMIN_SEED_EMAIL=admin@bb.test
ADMIN_SEED_PASSWORD=changeme123
ADMIN_SEED_NAME=Super Admin

# Upload (local disk + static serve)
UPLOAD_TEMP_DIR=./uploads/temporary
# Optional override for absolute URL prefix returned in upload responses.
# Leave blank to use BASE_URL + /static/temporary.
UPLOAD_PUBLIC_BASE_URL=
UPLOAD_MAX_BYTES=10485760

# Base URL used for absolute URL composition (uploads, OTP links if any)
BASE_URL=http://localhost:3000

# SMTP (forgot-password, account deletion OTP delivery)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@brainboost.local
SMTP_SECURE=false

# Logging
LOG_LEVEL=info

# Xendit (commerce payment gateway — Invoice API hosted checkout)
# Get from Xendit dashboard. Leave blank to disable charge dispatch (tests stub these).
XENDIT_SECRET_KEY=
XENDIT_CALLBACK_TOKEN=
# Deep-link URLs Xendit hosted invoice page redirects to after pay attempt (mobile WebView).
XENDIT_INVOICE_SUCCESS_URL=brainboost://payment/result?status=success
XENDIT_INVOICE_FAILURE_URL=brainboost://payment/result?status=failure

# Commerce expiry windows
COMMERCE_TRANSACTION_EXPIRY_HOURS=24
COMMERCE_INVOICE_EXPIRY_HOURS=24

# Legacy MariaDB (read-only — consumed by scripts/*.ts migration/backfill only).
# Not required by the app itself; leave blank unless running migration scripts.
LEGACY_DB_HOST=
LEGACY_DB_USER=
LEGACY_DB_PASS=
LEGACY_DB_NAME=tribelio_db
