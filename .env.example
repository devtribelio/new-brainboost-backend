# Application
NODE_ENV=development
PORT=3000
APP_NAME=bb-backend

TRUST_PROXY=1

# Database (Postgres)
DATABASE_URL=

# JWT
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=30d

# Admin panel
ADMIN_JWT_SECRET=
ADMIN_JWT_TTL=8h
ADMIN_COOKIE_NAME=
# Used by `pnpm tsx prisma/seed-admin.ts` to bootstrap the first superadmin
ADMIN_SEED_EMAIL=
ADMIN_SEED_PASSWORD=
ADMIN_SEED_NAME=

# Upload (local disk + static serve)
UPLOAD_TEMP_DIR=./uploads/temporary
UPLOAD_PUBLIC_BASE_URL=

# Base URL used for absolute URL composition (uploads, OTP links if any)
BASE_URL=http://localhost:3000

GOOGLE_CLIENT_IDS=

# Logging
LOG_LEVEL=info

XENDIT_SECRET_KEY=
XENDIT_CALLBACK_TOKEN=
XENDIT_BASE_URL=
XENDIT_INVOICE_SUCCESS_URL=
XENDIT_INVOICE_FAILURE_URL=


# Legacy MariaDB (read-only — consumed by scripts/*.ts migration/backfill only).
# Not required by the app itself; leave blank unless running migration scripts.
LEGACY_DB_HOST=
LEGACY_DB_USER=
LEGACY_DB_PASS=
LEGACY_DB_NAME=

BUNNY_ACCOUNT_API_KEY=
BUNNY_STREAM_CDN_HOST=
BUNNY_STREAM_LIBRARY_ID=
BUNNY_STREAM_TOKEN_KEY=
BUNNY_REFERER=
MEDIA_TOKEN_SECRET=
MEDIA_TOKEN_TTL_SECONDS=
MEDIA_DEFAULT_RESOLUTION=
MEDIA_MODE=

S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_PUBLIC_BASE_URL=

# Backoffice JSON API (apps/backoffice-api)
BACKOFFICE_JWT_SECRET=
BACKOFFICE_ACCESS_TTL=
BACKOFFICE_REFRESH_TTL_DAYS=
BACKOFFICE_2FA_ENC_KEY=
BACKOFFICE_2FA_ISSUER=

REVENUECAT_WEBHOOK_AUTH=

FCM_SERVICE_ACCOUNT_JSON=

RABBITMQ_URL=

# --- Sumsub KYC (affiliate disbursement gate; see docs/kyc-sumsub.md) ---
# App token + secret from dashboard (Dev space -> App tokens). Sandbox & prod = different pairs.
SUMSUB_APP_TOKEN=
SUMSUB_SECRET_KEY=
# Webhook endpoint secret (dashboard -> Webhooks). NOT the same as SUMSUB_SECRET_KEY.
SUMSUB_WEBHOOK_SECRET=
# Verification level name created in the dashboard.
SUMSUB_LEVEL_NAME=basic-kyc-idn
SUMSUB_BASE_URL=https://api.sumsub.com
# SDK access token lifetime, seconds.
SUMSUB_TOKEN_TTL_SECONDS=600

# --- Optional overrides (defaults in packages/common/src/config/env.ts) ---
# Sign in with Apple: iOS bundle id(s), comma-separated. Empty = Apple flow off.
APPLE_CLIENT_IDS=
# Bunny Stream management API key (metadata calls only).
BUNNY_STREAM_API_KEY=
# FCM push project id (pairs with FCM_SERVICE_ACCOUNT_JSON above).
FCM_PROJECT_ID=
# RevenueCat ThirdPartyCredential.name row (default: revenuecat).
REVENUECAT_PROVIDER_NAME=revenuecat
# RabbitMQ vhost for the comms outbox (default: comms).
RABBITMQ_VHOST=comms
# Comms outbox relay tuning.
COMMS_RELAY_INTERVAL_MS=2000
COMMS_RELAY_BATCH_SIZE=50
# S3-compatible endpoint (MinIO/R2). Empty = AWS default.
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=false
S3_PRESIGN_EXPIRES=900
S3_IMAGE_MAX_DIMENSION=1024
S3_IMAGE_WEBP_QUALITY=82
# Media token/signed-URL lifetimes, seconds.
MEDIA_SIGNED_URL_TTL_SECONDS=7200
MEDIA_DOWNLOAD_TTL_SECONDS=86400

# --- Amazon SQS (comms outbox) ---
SQS_REGION=
# Lokal (ElasticMQ): isi endpoint + dummy creds. Prod: KOSONGIN semua 3 ini (pakai IAM role)
SQS_ENDPOINT=http://localhost:9324
SQS_ACCESS_KEY_ID=x
SQS_SECRET_ACCESS_KEY=x
SQS_COMMS_URGENT_URL=http://localhost:9324/000000000000/comms-urgent
SQS_COMMS_NORMAL_URL=http://localhost:9324/000000000000/comms-normal
# (COMMS_RELAY_INTERVAL_MS / COMMS_RELAY_BATCH_SIZE tetap)
